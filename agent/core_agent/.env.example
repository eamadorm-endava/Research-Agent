# --- Vertex AI / Gemini model auth (local dev) ---
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# These are read by agent/core_agent/config.py
PROJECT_ID=${GOOGLE_CLOUD_PROJECT}
REGION=${GOOGLE_CLOUD_LOCATION}
MODEL_ARMOR_TEMPLATE_ID=your-model-armor-template-id

# --- Gemini Enterprise delegated OAuth (production) ---
# This must match the authorizationId you create when registering an authorization resource
# in Gemini Enterprise for Google Drive.
GEMINI_ENTERPRISE_AUTH_ID=drive-oauth

# --- Local Drive OAuth fallback (ONLY for local testing) ---
# Set ALLOW_LOCAL_OAUTH=true to enable.
ALLOW_LOCAL_OAUTH=false
# Path to downloaded OAuth client JSON (Desktop app recommended for local notebooks/dev)
GOOGLE_OAUTH_CLIENT_SECRETS=client_secret.json
# Where to cache local tokens
DRIVE_TOKEN_CACHE=.cache/drive_token.json

# --- Optional alternative auth ---
# Use Application Default Credentials for Drive calls (service account or user ADC).
# This is NOT Gemini Enterprise delegated access.
USE_ADC_FOR_DRIVE=false
